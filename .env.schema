# Linear Claude Skill - Environment Schema
# @defaultSensitive=true @defaultRequired=infer

# Linear Agent OAuth Token - Preferred for all operations (agent identity)
# Obtained via: npx tsx scripts/oauth-setup.ts
# @type=string @required=false @sensitive
LINEAR_AGENT_TOKEN=

# Linear Personal API Key - Fallback if agent token is not set
# @type=string(startsWith=lin_api_) @required=false @sensitive
LINEAR_API_KEY=

# Default initiative UUID for createProjectWithDefaults()
# @type=string @required=false @sensitive=false
LINEAR_DEFAULT_INITIATIVE_ID=
